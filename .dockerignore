# Keep Docker build contexts tiny so each service rebuild doesn't ship
# build artifacts, node_modules, or IDE files into the daemon.

.git/
.github/
.idea/
.vscode/
*.iml

**/build/
**/.gradle/
**/out/
**/bin/

web/node_modules/
web/dist/
ml-api/.venv/
ml-api/__pycache__/

*.log
.DS_Store
.env
.env.*
!.env.example
