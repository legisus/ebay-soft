<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared logback profile for production / staging. Services include it via
    <include resource="logback-json.xml"/>
  in their own logback-spring.xml. Emits one JSON object per line — Loki ingests via
  the docker driver or promtail.
-->
<configuration scan="false">

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <includeMdcKeyName>tenantId</includeMdcKeyName>
      <includeMdcKeyName>userId</includeMdcKeyName>
      <includeMdcKeyName>traceId</includeMdcKeyName>
      <includeMdcKeyName>spanId</includeMdcKeyName>
      <customFields>{"service":"${spring.application.name:-unknown}"}</customFields>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>

</configuration>
